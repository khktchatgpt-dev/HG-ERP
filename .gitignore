# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — local machine settings + worktrees (skills are shared)
.claude/settings.local.json
.claude/worktrees/

# External skills (npx skills add): commit source in .agents/, ignore the
# machine-specific absolute symlinks. Re-create per machine with:
#   npx skills add supabase/agent-skills
.claude/skills/supabase
.claude/skills/supabase-postgres-best-practices
